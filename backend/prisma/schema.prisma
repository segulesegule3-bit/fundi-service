datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User role management
enum Role {
  CUSTOMER
  FUNDI
  ADMIN
  SUPER_ADMIN
  SUPPORT
  CORPORATE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  ON_THE_WAY
  STARTED
  COMPLETED
  CANCELLED
  PRICE_CONFIRMED
}

enum PaymentStatus {
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED_REFUNDED
  RESOLVED_RELEASED
}

// 1. Core Users Table
model User {
  id              String        @id @default(uuid())
  phoneNumber     String        @unique
  email           String?       @unique
  fullName        String
  passwordHash    String
  role            Role          @default(CUSTOMER)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  customerProfile CustomerProfile?
  fundiProfile    FundiProfile?
  wallet          Wallet?
  sessions        LoginSession[]
  auditLogs       AuditLog[]
  otpVerifications OTPVerification[]
  deviceTokens    DeviceToken[]
  tickets         SupportTicket[]
  messagesSent    Message[]     @relation("Sender")
  notifications   Notification[]
  corporateEmployee CorporateEmployee?
}

// 2. Customer Profile
model CustomerProfile {
  id          String        @id @default(uuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  address     String?
  favorites   Favorite[]
  bookings    Booking[]
  created_at  DateTime      @default(now())
}

// 3. Fundi Profile
model FundiProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                 String?
  experienceYears     Int                @default(1)
  startingPrice       Decimal            @db.Decimal(12, 2) @map("starting_price")
  verifiedBadge       Boolean            @default(false)
  isOnline            Boolean            @default(false)
  
  // Custom Registration Fields
  nationalIdNumber    String?
  education           String?
  languagesSpoken     String?
  workingRadius       Float?             @default(15.0)
  emergencyService    Boolean            @default(false)
  regionId            Int?
  districtId          Int?
  wardId              Int?

  // Upgraded Fields
  serviceAreaType     String             @default("RADIUS") @map("service_area_type")
  serviceAreaRadius   Float              @default(15.0) @map("service_area_radius")
  languagesSpokenList String[]           @default([]) @map("languages_spoken")
  emergencyServiceEnabled Boolean        @default(false) @map("emergency_service_enabled")
  vacationMode        Boolean            @default(false) @map("vacation_mode")
  vacationStart       DateTime?          @map("vacation_start")
  vacationEnd         DateTime?          @map("vacation_end")
  lunchBreakStart     String?            @map("lunch_break_start")
  lunchBreakEnd       String?            @map("lunch_break_end")
  identityVerified    Boolean            @default(false) @map("identity_verified")
  professionVerified  Boolean            @default(false) @map("profession_verified")
  certificateVerified Boolean            @default(false) @map("certificate_verified")
  vetaCertified       Boolean            @default(false) @map("veta_certified")
  premiumFundi        Boolean            @default(false) @map("premium_fundi")
  topRated            Boolean            @default(false) @map("top_rated")
  backgroundChecked   Boolean            @default(false) @map("background_checked")
  lastActiveAt        DateTime           @default(now()) @map("last_active_at")
  inspectionFee       Decimal            @default(0.00) @map("inspection_fee") @db.Decimal(12, 2)

  // Relations
  professions         FundiProfession[]
  portfolio           PortfolioImage[]
  certificates        Certificate[]
  licenses            License[]
  experiences         WorkExperience[]
  schedule            AvailabilitySchedule[]
  bookings            Booking[]
  favorites           Favorite[]
  reviews             Review[]
  subscriptions       Subscription[]
  verificationStatuses VerificationStatus[]
  educationList       Education[]
  trustScore          TrustScore?
  badges              FundiBadge[]
  level               FundiLevel?
  
  createdAt           DateTime           @default(now())
}

// 4. Categories & Services
model Category {
  id          String        @id @default(uuid())
  nameEn      String        @unique
  nameSw      String
  iconName    String
  fundis      FundiProfession[]
  services    Service[]
}

model Service {
  id          String        @id @default(uuid())
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  basePrice   Decimal       @db.Decimal(12, 2)
  bookings    Booking[]
}

// 5. Bookings
model Booking {
  id             String        @id @default(uuid())
  customerId     String
  customer       CustomerProfile @relation(fields: [customerId], references: [id])
  fundiId        String
  fundi          FundiProfile  @relation(fields: [fundiId], references: [id])
  serviceId      String
  service        Service       @relation(fields: [serviceId], references: [id])
  status         BookingStatus @default(PENDING)
  date           DateTime
  address        String
  description    String?
  servicePrice   Decimal       @db.Decimal(12, 2)
  startingPrice       Decimal?      @db.Decimal(12, 2) @map("starting_price")
  inspectionFee       Decimal?      @db.Decimal(12, 2) @map("inspection_fee")
  customerBudget      Decimal?      @db.Decimal(12, 2) @map("customer_budget")
  aiEstimatedMin      Decimal?      @db.Decimal(12, 2) @map("ai_estimated_min")
  aiEstimatedMax      Decimal?      @db.Decimal(12, 2) @map("ai_estimated_max")
  fundiQuotePrice     Decimal?      @db.Decimal(12, 2) @map("fundi_quote_price")
  fundiQuoteArrival   String?       @map("fundi_quote_arrival")
  fundiQuoteCompletion String?      @map("fundi_quote_completion")
  fundiQuoteNotes     String?       @map("fundi_quote_notes")
  finalAgreedPrice    Decimal?      @db.Decimal(12, 2) @map("final_agreed_price")
  negotiationStatus   String?       @default("none") @map("negotiation_status")
  lastNegotiatedBy    String?       @map("last_negotiated_by")
  lastNegotiationPrice Decimal?     @db.Decimal(12, 2) @map("last_negotiation_price")
  paymentOption        String       @default("online") @map("payment_option")
  corporateId          String?      @map("corporate_id")
  corporate            CorporateAccount? @relation("CorporateBookings", fields: [corporateId], references: [id])
  warrantyPeriod       String?      @default("No Warranty") @map("warranty_period")
  warranty             Warranty?
  
  payment        Payment?
  review         Review?
  dispute        Dispute?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
}

// 6. Payments & Escrow Ledger
model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount            Decimal       @db.Decimal(12, 2)
  commissionAmount  Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(HELD_IN_ESCROW)
  gateway           String        @default("wallet") // mpesa, tigopesa, airtelmoney, card
  escrowDeadline    DateTime
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// 7. Wallet & Transactions
model Wallet {
  id            String              @id @default(uuid())
  userId        String              @unique
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal             @default(0.00) @db.Decimal(12, 2)
  lockedBalance Decimal             @default(0.00) @db.Decimal(12, 2)
  currency      String              @default("TZS")
  transactions  WalletTransaction[]
  updatedAt     DateTime            @updatedAt
}

model WalletTransaction {
  id          String        @id @default(uuid())
  walletId    String
  wallet      Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  type        String        // deposit, withdraw, escrow_hold, escrow_release, refund
  status      String        @default("completed")
  referenceId String?
  signature   String        // SHA-256 integrity signature
  createdAt   DateTime      @default(now())
}

// 8. Reviews
model Review {
  id          String        @id @default(uuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fundiId     String
  fundi       FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  createdAt   DateTime      @default(now())

  @@index([rating])
}

// 9. Notifications & Device Tokens
model Notification {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  isRead      Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

model DeviceToken {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String        @unique
  platform    String        // android, ios
  createdAt   DateTime      @default(now())
}

// 10. Subscriptions
model Subscription {
  id              String        @id @default(uuid())
  fundiId         String
  fundi           FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  tier            String        // silver, gold, premium
  startDate       DateTime      @default(now())
  endDate         DateTime
  paymentReference String?      @unique
}

// 11. OTP Verification
model OTPVerification {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash    String
  purpose     String        // registration, password_reset, sensitive_action
  expiresAt   DateTime
  verified    Boolean       @default(false)
  createdAt   DateTime      @default(now())
}

// 12. Sessions & Audit Logs
model LoginSession {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken  String        @unique
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime      @default(now())
}

model AuditLog {
  id          String        @id @default(uuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  ipAddress   String?
  userAgent   String?
  details     Json          @default("{}")
  createdAt   DateTime      @default(now())
}

// 13. System Settings
model SystemSetting {
  key         String        @id
  value       String
  description String?
  updatedAt   DateTime      @updatedAt
}

// 14. Support Tickets
model SupportTicket {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  description String
  status      String        @default("open") // open, resolved, closed
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// 15. Favorites
model Favorite {
  id          String          @id @default(uuid())
  customerId  String
  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fundiId     String
  fundi       FundiProfile    @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@unique([customerId, fundiId])
}

// 16. Portfolio, Certificates & Work Experience
model PortfolioImage {
  id              String        @id @default(uuid())
  fundiId         String
  fundi           FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  imageUrl        String
  description     String?
  mediaUrls       String[]      @default([]) @map("media_urls")
  videoUrl        String?       @map("video_url")
  beforeImageUrl  String?       @map("before_image_url")
  afterImageUrl   String?       @map("after_image_url")
  completionDate  DateTime?     @map("completion_date")
  clientApproved  Boolean       @default(false) @map("client_approved")
  serviceCategory String?       @map("service_category")
  location        String?
  clientReviewId  String?       @map("client_review_id")
  createdAt       DateTime      @default(now())

  @@map("portfolio_items")
}

model Certificate {
  id                 String        @id @default(uuid())
  fundiId            String        @map("fundi_id")
  fundi              FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  name               String
  institution        String
  certificateNumber  String        @map("certificate_number")
  issueDate          DateTime      @map("issue_date")
  expiryDate         DateTime?     @map("expiry_date")
  imageUrl           String?       @map("image_url")
  verificationStatus String        @default("pending_verification") @map("verification_status")
  createdAt          DateTime      @default(now())

  @@map("certificates")
}

model Education {
  id             String        @id @default(uuid())
  fundiId        String        @map("fundi_id")
  fundi          FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  institution    String
  course         String
  level          String
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  createdAt      DateTime      @default(now())

  @@map("education")
}

model WorkExperience {
  id             String        @id @default(uuid())
  fundiId        String
  fundi          FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  companyName    String
  role           String
  startDate      DateTime
  endDate        DateTime?
  description    String?
}

// 17. Availability Schedule
model AvailabilitySchedule {
  id                  String        @id @default(uuid())
  fundiId             String
  fundi               FundiProfile  @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  dayOfWeek           Int           // 0 (Sunday) to 6 (Saturday)
  startTime           String        // "08:00"
  endTime             String        // "17:00"
  emergencyAvailable  Boolean       @default(false)
}

// 18. Chat Messages
model Message {
  id             String        @id @default(uuid())
  chatRoomId     String
  senderId       String
  sender         User          @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  text           String?
  attachmentUrl  String?
  attachmentType String?       // image, voice_note, video
  createdAt      DateTime      @default(now())
}

// 19. Dispute Board
model Dispute {
  id             String        @id @default(uuid())
  bookingId      String        @unique
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reason         String
  status         DisputeStatus @default(OPEN)
  resolutionNotes String?
  createdAt      DateTime      @default(now())
}

// 20. PalmPay Transaction Ledger
model PaymentTransaction {
  id                    String   @id @default(uuid())
  userId                String
  provider              String   // PALMPAY
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("TZS")
  status                String   // PENDING, SUCCESS, FAILED
  referenceId           String   @unique
  providerTransactionId String?
  phoneNumber           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// 21. Webhook Logs
model WebhookLog {
  id        String   @id @default(uuid())
  provider  String   // PALMPAY
  payload   Json
  signature String
  verified  Boolean
  createdAt DateTime @default(now())
}

// 22. Live GPS Coordinates
model FundiLocation {
  id        String   @id @default(uuid())
  fundiId   String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())

  @@index([fundiId])
}

// 23. Booking Smart Dispatch queue
model JobDispatchQueue {
  id            String   @id @default(uuid())
  jobId         String
  fundiId       String
  status        String   // PENDING, SENT, REJECTED, ACCEPTED
  attemptNumber Int      @default(1)
  createdAt     DateTime @default(now())
}

// 24. AI Matching & Recommendations
model AIRecommendationLog {
  id           String   @id @default(uuid())
  customerId   String
  fundiId      String
  matchedScore Float
  action       String   // SENT, ACCEPTED, REJECTED
  createdAt    DateTime @default(now())
}

// 25. Demand Predictions
model AIDemandPrediction {
  id             String   @id @default(uuid())
  categoryId     String
  region         String
  predictedCount Int
  timeWindow     String
  createdAt      DateTime @default(now())
}

// 26. App Versions Management
model AppVersion {
  id           String   @id @default(uuid())
  appType      String   // "customer" or "fundi"
  version      String   // e.g. "1.0.0"
  fileName     String   // e.g. "customer-v1.0.0.apk"
  downloadUrl  String   // e.g. "/download/customer"
  releaseNotes String?
  isLatest     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([appType, isLatest])
}

// 27. Many-to-Many Join model for Fundi Professions
model FundiProfession {
  id             String       @id @default(uuid())
  fundiId        String       @map("fundiId")
  fundiProfile   FundiProfile @relation(fields: [fundiId], references: [id], onDelete: Cascade)
  professionId   String       @map("professionId")
  profession     Category     @relation(fields: [professionId], references: [id], onDelete: Cascade)
  isPrimary      Boolean      @default(false)
  experienceYears Int         @default(0) @map("experience_years")
  skillLevel     String       @default("Beginner") @map("skill_level")
  startingPrice  Decimal      @default(0.00) @map("starting_price") @db.Decimal(12, 2)
  minimumPrice   Decimal      @default(0.00) @map("minimum_price") @db.Decimal(12, 2)
  maximumPrice   Decimal      @default(0.00) @map("maximum_price") @db.Decimal(12, 2)
  emergencyPrice Decimal      @default(0.00) @map("emergency_price") @db.Decimal(12, 2)
  weekendPrice   Decimal      @default(0.00) @map("weekend_price") @db.Decimal(12, 2)
  inspectionFee  Decimal      @default(0.00) @map("inspection_fee") @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())

  @@map("fundi_professions")
}

// 28. Licenses Table
model License {
  id             String       @id @default(uuid())
  fundiProfileId String       @map("fundi_profile_id")
  fundi          FundiProfile @relation(fields: [fundiProfileId], references: [id], onDelete: Cascade)
  licenseNumber  String       @map("license_number")
  authority      String
  expiryDate     DateTime     @map("expiry_date")
  status         String       @default("active")
  credentialUrl  String?      @map("credential_url")
  createdAt      DateTime     @default(now())

  @@map("licenses")
}

// 29. NIDA / manual verification logs and statuses
model VerificationStatus {
  id              String       @id @default(uuid())
  fundiProfileId  String
  fundi           FundiProfile @relation(fields: [fundiProfileId], references: [id], onDelete: Cascade)
  nidaNumber      String
  status          String       @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, VERIFIED, REJECTED
  verifiedAt      DateTime?
  responsePayload String?      // Serialized NIDA API JSON payload
  createdAt       DateTime     @default(now())

  @@map("nida_verification_logs")
}

// 30. Corporate Accounts
model CorporateAccount {
  id              String             @id @default(uuid())
  companyName     String             @map("company_name")
  tinNumber       String?            @map("tin_number")
  billingAddress  String?            @map("billing_address")
  createdAt       DateTime           @default(now()) @map("created_at")
  employees       CorporateEmployee[]
  bookings        Booking[]          @relation("CorporateBookings")
  
  @@map("corporate_accounts")
}

model CorporateEmployee {
  id              String             @id @default(uuid())
  corporateId     String             @map("corporate_id")
  corporate       CorporateAccount   @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  userId          String             @unique @map("user_id")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String             @default("employee") // manager, employee
  createdAt       DateTime           @default(now()) @map("created_at")
  
  @@map("corporate_employees")
}

model SystemConfig {
  id                  String   @id @default(uuid())
  commissionRate      Decimal  @default(0.10) @db.Decimal(5, 2) @map("commission_rate")
  subscriptionBasic   Decimal  @default(29000.00) @db.Decimal(12, 2) @map("sub_basic")
  subscriptionPro     Decimal  @default(59000.00) @db.Decimal(12, 2) @map("sub_pro")
  subscriptionPremium Decimal  @default(99000.00) @db.Decimal(12, 2) @map("sub_premium")
  promotionFee        Decimal  @default(15000.00) @db.Decimal(12, 2) @map("promotion_fee")
  inspectionFeeBase   Decimal  @default(5000.00) @db.Decimal(12, 2) @map("inspection_fee_base")
  corporateDiscount   Decimal  @default(0.15) @db.Decimal(5, 2) @map("corporate_discount")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model Warranty {
  id              String          @id @default(uuid())
  bookingId       String          @unique @map("booking_id")
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  warrantyNumber  String          @unique @map("warranty_number")
  duration        String
  startDate       DateTime        @default(now()) @map("start_date")
  expiryDate      DateTime        @map("expiry_date")
  qrCodeData      String          @map("qr_code_data")
  certificateUrl  String?         @map("certificate_url")
  claims          WarrantyClaim[]
  createdAt       DateTime        @default(now()) @map("created_at")

  @@map("warranties")
}

model WarrantyClaim {
  id              String   @id @default(uuid())
  warrantyId      String   @map("warranty_id")
  warranty        Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
  description     String
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, RESOLVED
  photosUrls      String[] @default([]) @map("photos_urls")
  adminOutcome    String?  @map("admin_outcome") // rework, reject, partial_compensation, full_refund
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("warranty_claims")
}

model TrustScore {
  id                 String       @id @default(uuid())
  fundiProfileId     String       @unique @map("fundi_profile_id")
  fundi              FundiProfile @relation(fields: [fundiProfileId], references: [id], onDelete: Cascade)
  score              Int          @default(100)
  verifiedIdentity   Boolean      @default(false) @map("verified_identity")
  verifiedCertificates Boolean    @default(false) @map("verified_certificates")
  jobsCompleted      Int          @default(0) @map("jobs_completed")
  avgRating          Decimal      @default(5.00) @db.Decimal(3, 2) @map("avg_rating")
  claimRate          Decimal      @default(0.00) @db.Decimal(5, 2) @map("claim_rate")
  cancellationRate   Decimal      @default(0.00) @db.Decimal(5, 2) @map("cancellation_rate")
  responseTimeMins   Int          @default(30) @map("response_time_mins")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@map("trust_scores")
}

model Badge {
  id          String       @id @default(uuid())
  name        String       @unique
  icon        String
  description String
  fundis      FundiBadge[]

  @@map("badges")
}

model FundiBadge {
  id             String       @id @default(uuid())
  fundiProfileId String       @map("fundi_profile_id")
  fundi          FundiProfile @relation(fields: [fundiProfileId], references: [id], onDelete: Cascade)
  badgeId        String       @map("badge_id")
  badge          Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([fundiProfileId, badgeId])
  @@map("fundi_badges")
}

model FundiLevel {
  id             String       @id @default(uuid())
  fundiProfileId String       @unique @map("fundi_profile_id")
  fundi          FundiProfile @relation(fields: [fundiProfileId], references: [id], onDelete: Cascade)
  currentLevel   String       @default("BRONZE") @map("current_level") // BRONZE, SILVER, GOLD, PLATINUM, DIAMOND, ELITE
  points         Int          @default(0)
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("fundi_levels")
}

model QualityReport {
  id        String   @id @default(uuid())
  title     String
  details   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("quality_reports")
}

