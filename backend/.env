PORT=5000
NODE_ENV=development

# Database Settings (Local Docker defaults)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fundi_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fundi_db

# Auth & Secrets
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRATION=24h

# SMS Gateway Config (mock, beem, twilio, africastalking)
SMS_GATEWAY=mock
BEEM_API_KEY=mock_beem_api_key
BEEM_SECRET_KEY=mock_beem_secret_key
BEEM_SENDER_ID=INFO
TWILIO_ACCOUNT_SID=mock_twilio_sid
TWILIO_AUTH_TOKEN=mock_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=mock_cloud
CLOUDINARY_API_KEY=mock_key
CLOUDINARY_API_SECRET=mock_secret

# Push Notifications
FIREBASE_CREDENTIALS_JSON=mock_firebase_json

# Payment Gateways Sandboxes
AZAMPAY_APP_NAME=FundiServiceTZ
AZAMPAY_CLIENT_ID=mock_azampay_id
AZAMPAY_CLIENT_SECRET=mock_azampay_secret
AZAMPAY_BASE_URL=https://sandbox.azampay.co.tz
MOCK_PAYMENT_REDIRECT_URL=http://localhost:3000/payment/callback
